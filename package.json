{
  "name": "mirai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "npm --prefix frontend run build",
    "check": "npm --prefix frontend run check",
    "lint": "oxlint .",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:performance": "playwright test tests/performance",
    "performance:fixture": "node scripts/generate-performance-fixture.mjs",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "test:release-notes": "node --test scripts/release-notes/*.test.mjs",
    "test:types": "tsc -p tests/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.9.1",
    "oxlint": "^1.15.0",
    "prettier": "^3.6.2",
    "typescript": "^7.0.2"
  }
}
