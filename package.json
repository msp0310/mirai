{
  "name": "mirai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "npm --prefix frontend run build",
    "check": "npm --prefix frontend run check",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test:e2e": "node scripts/run-playwright.mjs test",
    "test:e2e:ui": "node scripts/run-playwright.mjs test --ui",
    "test:performance": "node scripts/run-playwright.mjs test tests/performance",
    "performance:fixture": "node scripts/generate-performance-fixture.mjs",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "test:release-notes": "node --test scripts/release-notes/*.test.mjs",
    "test:types": "tsc -p tests/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.9.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.15.0",
    "typescript": "^7.0.2"
  }
}
