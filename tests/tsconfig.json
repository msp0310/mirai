{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "..",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": [
    "./**/*.ts",
    "../frontend/src/data/scheduleRepository.ts",
    "../frontend/src/lib/resourceCalculations.ts",
    "../frontend/src/lib/schedule.ts",
    "../frontend/src/lib/members.ts",
    "../frontend/src/types/schedule.ts"
  ]
}
