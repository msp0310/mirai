{
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "pedantic": "off",
    "perf": "warn",
    "style": "warn",
    "restriction": "off",
    "nursery": "off"
  },
  "rules": {
    "func-style": "off",
    "id-length": "off",
    "max-params": "off",
    "max-statements": "off",
    "no-await-in-loop": "off",
    "no-continue": "off",
    "no-magic-numbers": "off",
    "no-nested-ternary": "off",
    "no-ternary": "off",
    "oxc/no-map-spread": "off",
    "sort-imports": "off",
    "sort-keys": "off",
    "typescript/consistent-type-definitions": "off",
    "unicorn/filename-case": "off",
    "unicorn/no-nested-ternary": "off",
    "unicorn/no-null": "off",
    "unicorn/prefer-global-this": "off"
  },
  "overrides": [
    {
      "files": ["frontend/src/features/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["**/app/**"],
                "message": "feature層からapp層へ依存できません。共有処理はlibまたはdataへ移してください。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["frontend/src/{components,data,hooks,lib}/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["**/app/**", "**/features/**"],
                "message": "共有層からappまたはfeature層へ依存できません。"
              }
            ]
          }
        ]
      }
    }
  ],
  "ignorePatterns": ["dist/**", "node_modules/**", "captures/**"]
}
